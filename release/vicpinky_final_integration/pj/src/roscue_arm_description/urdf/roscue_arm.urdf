    <origin rpy="0.000000 0.000000 -0.000000" xyz="-0.063000 -0.001525 -0.000300"/>
    <axis xyz="0.000000 -1.000000 0.000000"/>
    <limit effort="100.0" lower="-1.9426" upper="1.9426" velocity="1.00"/>
  </joint>
  <!-- ROS 2 control: gripper-only mock system. -->
  <ros2_control name="roscue_gripper_system" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
      <param name="cmd_topic">sim/roscue_gripper_system/cmd</param>
      <param name="state_topic">sim/roscue_gripper_system/state</param>
    </hardware>
    <joint name="finger_1_base_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="finger_1_middle_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="finger_1_tip_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="finger_2_base_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="finger_2_middle_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="finger_2_tip_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="finger_3_base_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="finger_3_middle_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="finger_3_tip_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
  <!--
    RealSense wrist mount measured in the final integration PDF. The camera
    driver owns camera_link's optical-frame children; robot_state_publisher
    only connects the camera root to the arm.
  -->
  <link name="camera_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.090 0.025 0.025"/>
      </geometry>
      <material name="camera_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.090 0.025 0.025"/>
      </geometry>
    </collision>
  </link>
  <joint name="camera_mount_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="camera_link"/>
    <origin rpy="1.57079633 -1.57079633 0.0" xyz="0.0 -0.070 0.057"/>
  </joint>
  <!-- Fixed button TCP: third-finger contact point from the final PDF. -->
  <link name="button_contact_link"/>
  <joint name="button_contact_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="button_contact_link"/>
    <origin rpy="0 0 0.52359878" xyz="-0.073434 -0.044148 0.179650"/>
  </joint>
  <!--
    Center of the three fingertip-joint origins at the configured closed
    object pose. Pick targets use this TCP instead of the palm origin.
  -->
  <link name="grasp_tcp_link"/>
  <joint name="grasp_tcp_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="grasp_tcp_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.134295"/>
  </joint>
</robot>
